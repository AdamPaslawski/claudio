# Required — get one at https://elevenlabs.io
ELEVEN_API_KEY=your_elevenlabs_api_key

# Optional overrides
WHISPER_MODEL=small                  # tiny, base, small, medium, large-v3
WHISPER_DEVICE=auto                  # cuda, cpu, auto
WHISPER_COMPUTE_TYPE=auto            # int8 (cpu), float16 (gpu), auto
ELEVEN_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVEN_MODEL_ID=eleven_flash_v2_5
ELEVEN_OUTPUT_FORMAT=mp3_44100_128
HOTKEY=space                         # key to hold for push-to-talk
CODE_BLOCK_MODE=summarize            # "summarize" or "read"
